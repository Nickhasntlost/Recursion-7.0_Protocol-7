# ============================================
# Event Booking System - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# MongoDB Configuration
# ============================================
# Option A: Local MongoDB (Recommended for development)
MONGODB_URL=mongodb://localhost:27017

# Option B: MongoDB Atlas (FREE Cloud - 512 MB)
# Get from: https://cloud.mongodb.com
# MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/

DATABASE_NAME=event_booking_system

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change SECRET_KEY in production!
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Application Configuration
# ============================================
APP_NAME=Event Booking System
APP_VERSION=1.0.0
DEBUG=True

# Frontend URLs (for CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ============================================
# Google Gemini AI (FREE!) ⭐
# ============================================
# Get FREE API key: https://makersuite.google.com/app/apikey
# Usage: 60 requests/minute - FREE forever
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-pro
GEMINI_VISION_MODEL=gemini-pro-vision

# ============================================
# Gmail SMTP (FREE Email Service) ⭐
# ============================================
# Get App Password: https://myaccount.google.com/apppasswords
# Usage: 500 emails/day - FREE
# Steps:
#   1. Enable 2FA on your Google Account
#   2. Go to: https://myaccount.google.com/apppasswords
#   3. Select "Mail" and "Other (Custom name)"
#   4. Copy the 16-character password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM_NAME=Event Booking System
SMTP_FROM_EMAIL=your-email@gmail.com

# ============================================
# File Upload (Temporary Storage - FREE) ⭐
# ============================================
# Files are automatically deleted after processing
UPLOAD_DIR=temp_uploads
MAX_UPLOAD_SIZE=10485760  # 10 MB in bytes

# ============================================
# Optional: MQTT Broker for IoT (FREE)
# ============================================
# Option A: Local Mosquitto (FREE)
# Install: https://mosquitto.org/download/
MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Option B: HiveMQ Cloud (FREE tier)
# Get from: https://www.hivemq.com/mqtt-cloud-broker/
# MQTT_BROKER_URL=your-cluster.hivemq.cloud
# MQTT_BROKER_PORT=8883
# MQTT_USERNAME=your-username
# MQTT_PASSWORD=your-password

# ============================================
# Optional: Blockchain Configuration (Phase 2)
# ============================================
# BLOCKCHAIN_NETWORK=sepolia
# INFURA_PROJECT_ID=your-infura-id
# PRIVATE_KEY=your-private-key

# ============================================
# Optional: AWS S3 (Not needed - we use temp storage)
# ============================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=
# AWS_REGION=us-east-1

# ============================================
# NOTES FOR PRODUCTION
# ============================================
# 1. Generate new SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# 2. Set DEBUG=False
#
# 3. Use MongoDB Atlas for cloud database
#
# 4. Set specific ALLOWED_ORIGINS (remove wildcards)
#
# 5. NEVER commit .env to Git!
#    (Add to .gitignore)
#
# 6. Rotate API keys every 3 months
#
# 7. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production

# ============================================
# FREE SERVICES USED - NO CREDIT CARD NEEDED!
# ============================================
# ✅ Google Gemini AI - FREE (60 req/min)
# ✅ Gmail SMTP - FREE (500 emails/day)
# ✅ Temporary File Storage - FREE (auto-delete)
# ✅ MongoDB Atlas - FREE (512 MB)
# ✅ MQTT Mosquitto - FREE (local)
#
# Total Cost: $0.00 per month! 🎉
